# API the flows + scripts hit. Use staging in CI, local in dev.
API_BASE_URL=https://staging-api.travelpilotapp.com

# Admin JWT minted via POST /api/v1/auth/login as e2e-bot@travelpilotapp.com.
# In CI, the workflow logs in at the start of the job and exports this.
ADMIN_TOKEN=

# Bearer used by the test reset endpoint. Must match TEST_RESET_TOKEN on the API.
TEST_RESET_TOKEN=

# Test users seeded by /api/v1/test/reset (see API repo's reset.service.ts).
TEST_FREE_EMAIL=e2e+freeuser@travelpilotapp.com
TEST_FREE_PASSWORD=E2eFreeUser!1
TEST_PREMIUM_EMAIL=e2e+premium@travelpilotapp.com
TEST_PREMIUM_PASSWORD=E2ePremium!1

# App identifiers — passed to flows as ${APP_ID}.
APP_ID_ANDROID=com.travelpilotapp
APP_ID_IOS=com.travelpilotapp

# Optional reporter context — defaults to git SHA / "unknown" when unset.
APP_VERSION=
APP_BUILD=
CI_RUN_URL=
